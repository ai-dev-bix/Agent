APP_NAME="AI Agents SaaS"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://yourdomain.com

# Database
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=your_database
DB_USERNAME=your_username
DB_PASSWORD=your_password

# Cache / Queue / Session
CACHE_STORE=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file

# Mail
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@yourdomain.com
MAIL_FROM_NAME="AI Agents SaaS"

# OpenAI
OPENAI_API_KEY=
OPENAI_ORGANIZATION=

# Payments
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYMENT_CURRENCY=USD

# Social Login
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Platform Settings
DEFAULT_FREE_MESSAGES=3
DEFAULT_CREDITS_PER_MESSAGE=1
INSTALLATION_COMPLETED=false
